# ===== Django =====
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
# Add your public host(s). A leading dot (.example.com) matches all subdomains.
# GitHub Codespaces forwarded domains are auto-trusted from CODESPACE_NAME,
# but you can also list .app.github.dev explicitly.
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,.app.github.dev
# CSRF origins must include scheme; wildcard subdomains are allowed.
CSRF_TRUSTED_ORIGINS=http://localhost,http://localhost:80,http://localhost:8000,http://127.0.0.1,http://127.0.0.1:80,http://127.0.0.1:8000,https://localhost,https://*.app.github.dev

# ===== MongoDB =====
MONGO_DB=itrendtasks
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_USERNAME=itrend
MONGO_PASSWORD=itrendpass
MONGO_AUTH_SOURCE=admin

# ===== Redis / Channels / Celery =====
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ===== JWT =====
JWT_SECRET=change-me-jwt-secret
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# ===== AI (OpenAI) =====
OPENAI_API_KEY=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
